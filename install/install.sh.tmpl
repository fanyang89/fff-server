#!/usr/bin/env bash
# Auto-generated by fff-server. Produced by the one-liner:
#   curl -fsSL '<server>/install.sh?name=...&url=...&scope=...&agent=...&target=...&notes=...' | bash
#
# Installs the configured skill into the local agent's skills directory and
# registers the MCP server. Parameters below are baked in by the server; every
# value is a single-quoted bash literal, so no runtime expansion of user input
# happens.
set -euo pipefail

NAME={{INSTANCE_NAME}}
URL={{INSTANCE_URL}}
SCOPE={{SCOPE}}
AGENT={{AGENT}}
TARGET={{TARGET}}
NOTES_ENC={{NOTES_ENC}}
ORIGIN={{ORIGIN}}

# 1. Resolve the target skill directory for the chosen agent × scope.
case "$AGENT:$TARGET" in
  opencode:global)  SKILL_DIR="$HOME/.config/opencode/skills/$NAME" ;;
  opencode:project) SKILL_DIR=".opencode/skills/$NAME" ;;
  claude:global)    SKILL_DIR="$HOME/.claude/skills/$NAME" ;;
  claude:project)   SKILL_DIR=".claude/skills/$NAME" ;;
  generic:global)   SKILL_DIR="$HOME/.config/opencode/skills/$NAME" ;;
  generic:project)  SKILL_DIR=".opencode/skills/$NAME" ;;
  *) echo "install: bad agent/target: $AGENT/$TARGET" >&2; exit 1 ;;
esac

# 2. Fetch the rendered SKILL.md (same params, server renders the body).
mkdir -p "$SKILL_DIR"
QUERY="name=$NAME&url=$URL&scope=$SCOPE&notes=$NOTES_ENC"
if ! curl -fsSL "$ORIGIN/install/skill.md?$QUERY" -o "$SKILL_DIR/SKILL.md"; then
  echo "install: failed to fetch SKILL.md from $ORIGIN" >&2
  exit 1
fi
echo "installed skill  -> $SKILL_DIR/SKILL.md"

# 3. Register the MCP server (best-effort; never fail the whole install).
case "$AGENT" in
  opencode)
    if command -v opencode >/dev/null 2>&1; then
      opencode mcp add "$NAME" --url "$URL" \
        || echo "(opencode mcp add skipped or already registered)"
    else
      echo "opencode CLI not on PATH; install it from https://opencode.ai"
      echo "then run: opencode mcp add $NAME --url $URL"
    fi
    ;;
  claude)
    if command -v claude >/dev/null 2>&1; then
      claude mcp add --transport http "$NAME" "$URL" \
        || echo "(claude mcp add skipped or already registered)"
    else
      echo "Claude Code CLI not on PATH; register manually:"
      echo "  claude mcp add --transport http $NAME $URL"
    fi
    ;;
  generic)
    echo "MCP endpoint: $URL"
    ;;
esac
