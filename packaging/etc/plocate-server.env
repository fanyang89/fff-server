# /etc/plocate-server/plocate-server.env — the single source of configuration
# for the plocate-server service (loaded via EnvironmentFile=).
#
# This file ships with defaults; edit it to match your tree. Upgrades never
# overwrite it (marked config(noreplace)). Every flag has a matching env var;
# see `plocate-server --help`.

# Root directory to index (REQUIRED — updatedb walks it). Adjust to your tree.
PLOCATE_SERVER_BASE_PATH=/srv/files

# HTTP bind address.
PLOCATE_SERVER_BIND=127.0.0.1:8787

# On-disk plocate database path (created/refreshed by updatedb).
PLOCATE_SERVER_DB_PATH=/var/lib/plocate-server/files.db

# Override the plocate / updatedb binaries (default: the vendored musl ones).
PLOCATE_SERVER_PLOCATE_BIN=/usr/libexec/plocate-server/plocate
PLOCATE_SERVER_UPDATEDB_BIN=/usr/libexec/plocate-server/updatedb

# Periodic index refresh is driven by plocate-server-updatedb.timer, which
# POSTs to /api/reindex. The server is the sole executor of updatedb (so the
# timer and the maintenance UI button can never race). No interval config here.

# Maximum results returned by a single search/glob call.
PLOCATE_SERVER_MAX_RESULTS=100

# Maximum concurrent plocate query processes; excess requests wait.
PLOCATE_SERVER_MAX_CONCURRENT_SEARCHES=8

# Per-query timeout (seconds); a plocate run exceeding this is killed (504).
PLOCATE_SERVER_SEARCH_TIMEOUT_SECS=10

# Per-reindex timeout (seconds); an updatedb run exceeding this is killed.
PLOCATE_SERVER_UPDATEDB_TIMEOUT_SECS=3600

# Logging filter. Defaults to info while suppressing noisy MCP connection logs.
# RUST_LOG=info,rmcp::service=warn
